# SIGIL Wallet Environment Configuration

# sigil-node API URL
# For local development, use: http://localhost:8181/api
# For production via q-flux, use: /api  (sigilgraph.com)
VITE_API_URL=http://localhost:8181/api

# Network identifier — DO NOT change without coordinating with sigil-node operators
VITE_NETWORK_ID=sigil-g0

# Stripe Payment Integration
# Get your publishable key from: https://dashboard.stripe.com/apikeys
# For testing, use test keys starting with "pk_test_"
# For production, use live keys starting with "pk_live_"
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
